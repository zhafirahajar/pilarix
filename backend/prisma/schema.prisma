generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())

  spms      Spm[]     @relation("CreatedBy")
  approvals Spm[]     @relation("ApprovedBy")
}

model Project {
  id         Int         @id @default(autoincrement())
  name       String
  location   String?
  createdAt  DateTime    @default(now())

  pekerjaans Pekerjaan[]
  transactions MaterialTransaction[]
  materialStocks ProjectMaterialStock[]
  spms Spm[]
  purchases Purchase[]
}

model Material {
  id            Int    @id @default(autoincrement())
  name          String
  unit          String
  type          MaterialItemType 


  usages       MaterialUsage[]
  transactions MaterialTransaction[]
  materialStocks ProjectMaterialStock[]
  spmItems      SpmItem[]
  analysisItems AnalysisItem[]
}

model Analysis {
  id          Int      @id @default(autoincrement())
  name        String   // contoh: cor beton
  unit        String   // m3
  totalPrice  Float
  createdAt   DateTime @default(now())

  items     AnalysisItem[]
  rabItems   RabItem[]
  materialUsages MaterialUsage[]
}

model AnalysisItem {
  id         Int   @id @default(autoincrement())
  analysisId Int
  materialId Int
  price       Float
  coefficient Float

  analysis   Analysis @relation(fields: [analysisId], references: [id])
  material   Material @relation(fields: [materialId], references: [id])
}

model Pekerjaan {
  projectId Int
  id        Int      @id @default(autoincrement())
  name      String   // contoh: POS, T.Staff

  rabItems  RabItem[]
  transactions MaterialTransaction[]
  project   Project  @relation(fields: [projectId], references: [id])
}

model RabItem {
  id          Int      @id @default(autoincrement())
  pekerjaanId Int
  analysisId  Int?   
  name        String
  parentId    Int?
  level       Int     // 1 = A, 2 = I, 3 = 1
  order       Int     // urutan tampil
  volume      Float?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?
  createdAt   DateTime @default(now())

  analysis    Analysis? @relation(fields: [analysisId], references: [id]) 
  pekerjaan   Pekerjaan @relation(fields: [pekerjaanId], references: [id])
  parent      RabItem?   @relation("RabHierarchy", fields: [parentId], references: [id])
  children    RabItem[]  @relation("RabHierarchy")
  
  materialTransactions MaterialTransaction[]
  materials   MaterialUsage[]
}

model MaterialUsage {
  id          Int   @id @default(autoincrement())
  rabItemId   Int
  analysisId  Int?   
  materialId  Int
  coefficient Float

  analysis    Analysis? @relation(fields: [analysisId], references: [id]) 
  rabItem     RabItem   @relation(fields: [rabItemId], references: [id])
  material    Material  @relation(fields: [materialId], references: [id])
}

model ProjectMaterialStock {
  id          Int @id @default(autoincrement())
  projectId   Int
  materialId  Int
  stock       Float @default(0)

  material    Material @relation(fields: [materialId], references: [id])
  project     Project @relation(fields: [projectId], references: [id])
  @@unique([projectId, materialId])
}

model MaterialTransaction {
  id          Int      @id @default(autoincrement())
  materialId  Int
  projectId   Int
  pekerjaanId Int?
  rabItemId   Int?
  quantity    Float
  type        TransactionType
  note        String?
  createdAt   DateTime @default(now())
  purchaseId  Int?

  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
  rabItem     RabItem? @relation(fields: [rabItemId], references: [id])
  material    Material @relation(fields: [materialId], references: [id])
  pekerjaan   Pekerjaan? @relation(fields: [pekerjaanId], references: [id])
  project     Project @relation(fields: [projectId], references: [id])
}

model Spm {
  id           Int      @id @default(autoincrement())
  spmNumber    String   @unique
  projectId    Int
  requestedById Int
  approvedById Int?
  note         String?
  createdAt    DateTime  @default(now())
  approvedAt   DateTime?

  project      Project @relation(fields: [projectId], references: [id])
  requestedBy  User    @relation("CreatedBy", fields: [requestedById], references: [id])
  approvedBy   User?   @relation("ApprovedBy", fields: [approvedById], references: [id])

  items        SpmItem[]
  status       SpmStatus @default(PENDING)
}

model SpmItem {
  id         Int   @id @default(autoincrement())
  spmId      Int
  materialId Int
  quantity   Float

  status     SpmItemStatus @default(REQUESTED)

  spm        Spm      @relation(fields: [spmId], references: [id])
  material   Material @relation(fields: [materialId], references: [id])
}

model Purchase {
  id            Int      @id @default(autoincrement())
  projectId     Int
  vendor        String?
  invoiceNumber String?
  purchasedAt   DateTime?
  totalAmount   Float?
  createdAt     DateTime @default(now())

  project       Project @relation(fields: [projectId], references: [id])
  transactions  MaterialTransaction[]  // 🔥 detail item
  receipts      PurchaseReceipt[]      // 🔥 file nota
}

model PurchaseReceipt {
  id            Int      @id @default(autoincrement())
  purchaseId    Int
  fileUrl       String
  fileName      String
  uploadedAt    DateTime @default(now())

  purchase      Purchase @relation(fields: [purchaseId], references: [id])
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum materialType {
  ALAT
  BAHAN
  UPAH
}

enum TransactionType {
  PURCHASE
  USAGE
  ADJUSTMENT
}

enum SpmStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIALLY_PURCHASED
  COMPLETED
}

enum SpmItemStatus {
  REQUESTED
  APPROVED
  PENDING_PURCHASE
  PURCHASED
}

enum MaterialItemType {
  MATERIAL
  LABOR
  EQUIPMENT
}