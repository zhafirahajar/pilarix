generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id         Int         @id @default(autoincrement())
  name       String
  location   String?
  createdAt  DateTime    @default(now())

  pekerjaans Pekerjaan[]
}

model Pekerjaan {
  id        Int      @id @default(autoincrement())
  name      String   // contoh: POS, T.Staff

  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])

  rabItems  RabItem[]
  transactions MaterialTransaction[]
}

model RabItem {
  id          Int      @id @default(autoincrement())

  pekerjaanId Int
  pekerjaan   Pekerjaan @relation(fields: [pekerjaanId], references: [id])

  name        String

  // 🔥 TREE STRUCTURE
  parentId    Int?
  parent      RabItem?   @relation("RabHierarchy", fields: [parentId], references: [id])
  children    RabItem[]  @relation("RabHierarchy")

  // 📊 HIERARCHY INFO
  level       Int     // 1 = A, 2 = I, 3 = 1
  order       Int     // urutan tampil

  // 💰 ONLY FOR LEAF NODES
  volume      Float?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?

  materials   MaterialUsage[]
  materialTransactions MaterialTransaction[]

  createdAt   DateTime @default(now())
}

model Material {
  id        Int    @id @default(autoincrement())
  name      String
  unit      String

  usages       MaterialUsage[]
  transactions MaterialTransaction[]
}

model MaterialUsage {
  id          Int   @id @default(autoincrement())

  rabItemId   Int
  materialId  Int

  quantity    Float

  rabItem     RabItem   @relation(fields: [rabItemId], references: [id])
  material    Material  @relation(fields: [materialId], references: [id])
}

model MaterialTransaction {
  id          Int      @id @default(autoincrement())

  materialId  Int
  material    Material @relation(fields: [materialId], references: [id])

  pekerjaanId Int
  pekerjaan   Pekerjaan @relation(fields: [pekerjaanId], references: [id])

  // optional: link ke pekerjaan spesifik di RAB
  rabItemId   Int?
  rabItem     RabItem? @relation(fields: [rabItemId], references: [id])

  quantity    Float

  type        TransactionType
  note        String?

  createdAt   DateTime @default(now())
}

enum TransactionType {
  PURCHASE
  USAGE
  ADJUSTMENT
}