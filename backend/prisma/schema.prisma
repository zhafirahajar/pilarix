generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id         Int         @id @default(autoincrement())
  name       String
  location   String?
  createdAt  DateTime    @default(now())

  pekerjaans Pekerjaan[]
  transactions MaterialTransaction[]
  materialStocks ProjectMaterialStock[]
}

model Pekerjaan {
  id        Int      @id @default(autoincrement())
  name      String   // contoh: POS, T.Staff
  projectId Int

  rabItems  RabItem[]
  transactions MaterialTransaction[]
  project   Project  @relation(fields: [projectId], references: [id])
}

model RabItem {
  id          Int      @id @default(autoincrement())
  pekerjaanId Int
  pekerjaan   Pekerjaan @relation(fields: [pekerjaanId], references: [id])
  name        String
  parentId    Int?
  level       Int     // 1 = A, 2 = I, 3 = 1
  order       Int     // urutan tampil
  volume      Float?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?
  createdAt   DateTime @default(now())

  materialTransactions MaterialTransaction[]
  materials   MaterialUsage[]
  parent      RabItem?   @relation("RabHierarchy", fields: [parentId], references: [id])
  children    RabItem[]  @relation("RabHierarchy")
}

model Material {
  id        Int    @id @default(autoincrement())
  name      String
  unit      String

  usages       MaterialUsage[]
  transactions MaterialTransaction[]
  materialStocks ProjectMaterialStock[]
}

model MaterialUsage {
  id          Int   @id @default(autoincrement())
  rabItemId   Int
  materialId  Int
  quantity    Float

  rabItem     RabItem   @relation(fields: [rabItemId], references: [id])
  material    Material  @relation(fields: [materialId], references: [id])
}

model ProjectMaterialStock {
  id          Int @id @default(autoincrement())
  projectId   Int
  materialId  Int
  stock       Float @default(0)

  material    Material @relation(fields: [materialId], references: [id])
  project     Project @relation(fields: [projectId], references: [id])
  @@unique([projectId, materialId])
}

model MaterialTransaction {
  id          Int      @id @default(autoincrement())
  materialId  Int
  projectId   Int
  pekerjaanId Int?
  rabItemId   Int?
  quantity    Float
  type        TransactionType
  note        String?
  createdAt   DateTime @default(now())

  rabItem     RabItem? @relation(fields: [rabItemId], references: [id])
  material    Material @relation(fields: [materialId], references: [id])
  pekerjaan   Pekerjaan? @relation(fields: [pekerjaanId], references: [id])
  project     Project @relation(fields: [projectId], references: [id])
}

enum TransactionType {
  PURCHASE
  USAGE
  ADJUSTMENT
}